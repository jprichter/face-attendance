DB_HOST=localhost
DB_NAME=face_attendance
DB_USER=postgres
DB_PASS=password
DB_PORT=5432
# Distance threshold (lower is stricter)
RECOGNITION_THRESHOLD=0.4
# Minimum consecutive frames to confirm identity
CONFIRMATION_FRAMES=3
# Cool-down in minutes between check-ins for the same person
CHECK_IN_COOLDOWN_MINUTES=1 # Reduced from 30 to 1 for testing purposes
# Path to save unknown faces
UNKNOWN_FACES_DIR=data/unknown/
# Camera source: 0 for webcam, or "rtsp://..."
CAMERA_SOURCE=0
